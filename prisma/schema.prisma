generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String              @id
  email     String
  name      String?
  createdAt DateTime            @default(now())
  threads   Thread[]
  layouts   DashboardLayout[]
  feedbacks MessageFeedback[]
}

model Thread {
  id                String    @id @default(cuid())
  userId            String
  langGraphThreadId String
  title             String    @default("새 대화")
  project           String    @default("default")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])
  messages          Message[]
}

model Message {
  id        String            @id @default(cuid())
  threadId  String
  role      String
  content   String
  createdAt DateTime          @default(now())
  thread    Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  feedback  MessageFeedback[]
}

model MessageFeedback {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model RiskItem {
  id         String    @id @default(cuid())
  projectId  String
  name       String
  system     String
  riskLevel  String
  mitigation String
  status     String    @default("OPEN")
  assignee   String?
  dueDate    DateTime?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Incident {
  id         String    @id @default(cuid())
  projectId  String
  title      String
  severity   String
  status     String    @default("OPEN")
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}

model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String
  project   String   @default("default")
  layout    String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, project])
}

model EvalPrompt {
  id         String   @id @default(cuid())
  name       String   @unique  // "hallucination", "citation", "tool_calling", or custom
  evalType   String   @default("llm_prompt") // "llm_prompt" | "code_rule" | "builtin"
  template   String   @default("")           // prompt text for llm_prompt, empty for code_rule
  ruleConfig String   @default("{}")         // JSON rule config for code_rule type
  isCustom   Boolean  @default(false)
  updatedAt  DateTime @updatedAt
}

model ProjectEvalConfig {
  id         String  @id @default(cuid())
  projectId  String
  evalName   String  // annotation name (e.g. "hallucination")
  enabled    Boolean @default(true)
  template   String? // project-specific prompt override (null = use global default)

  @@unique([projectId, evalName])
}

model AgentConfig {
  id          String   @id @default(cuid())
  project     String   @unique          // Phoenix project name
  alias       String?                   // Display name in dashboard (null = use project name)
  templateId  String?                   // AgentTemplate reference (null = custom)
  agentType   String   @default("langgraph")
  endpoint    String   @default("http://localhost:2024")
  assistantId String   @default("agent")
  updatedAt   DateTime @updatedAt
  template    AgentTemplate? @relation(fields: [templateId], references: [id])
}

model AgentTemplate {
  id          String        @id @default(cuid())
  name        String        @unique    // "Legal RAG", "Financial Research", etc.
  description String        @default("")
  agentType   String        @default("langgraph")
  endpoint    String        @default("http://localhost:2024")
  assistantId String        @default("agent")
  evalPrompts String        @default("{}") // JSON: {"hallucination": "...", "citation": "..."}
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  configs     AgentConfig[]
}
